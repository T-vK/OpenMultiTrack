#!/usr/bin/env bash
# Only allow commits on main — commit directly to main, never on feature branches.
set -euo pipefail

branch="$(git branch --show-current 2>/dev/null || true)"

if [[ -z "$branch" ]]; then
  exit 0
fi

if [[ "$branch" != "main" ]]; then
  cat >&2 <<EOF
Rejected: commits are only allowed on branch "main" (current: "$branch").

This project does not use feature branches or pull requests.
  git checkout main

Then commit and push directly to main.
EOF
  exit 1
fi

exit 0
