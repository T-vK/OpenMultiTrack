#!/usr/bin/env bash
# Only allow pushing main to remotes — no feature branches, no PR workflow.
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$local_ref" == refs/heads/* ]] || continue
  branch="${local_ref#refs/heads/}"
  if [[ "$branch" != "main" ]]; then
    cat >&2 <<EOF
Rejected: only branch "main" may be pushed (attempted: "$branch").

This project does not use feature branches or pull requests.
Commit on main and push:

  git checkout main
  git push origin main
EOF
    exit 1
  fi
done

exit 0
